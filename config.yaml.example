server:
  port: 8080
  mode: release
  # WebSocket 允许的 Origin（小程序可留空，浏览器客户端需配置）
  allowed_origins: []

mysql:
  host: 127.0.0.1
  port: 3306
  user: root
  password: "CHANGE_ME"
  database: recipe_app

jwt:
  secret: "CHANGE_ME"
  expire_hours: 720

wechat:
  appid: "YOUR_MINIAPP_APPID"
  secret: "YOUR_MINIAPP_SECRET"
  # 内容安全 msgSecCheck（小程序审核必需，默认 true）
  sec_check_enabled: true

oss:
  endpoint: "oss-cn-xxx.aliyuncs.com"
  access_key_id: ""
  access_key_secret: ""
  bucket: ""
  region: "cn-hangzhou"
  custom_domain: ""

redis:
  addr: "127.0.0.1:6379"
  password: ""
  db: 0

weather:
  enabled: true
  provider: "open_meteo"
  default_city: "成都"
  default_lat: 30.5728
  default_lon: 104.0668
  cache_ttl_hours: 3

ai:
  recommend_enabled: true   # false 时前端隐藏 AI 推荐，/api/ai/* 返回 403
  catalog_enabled: true     # false 时关闭 /api/catalog-recipes/*（默认随 recommend_enabled）
  catalog_default_variant_label: "经典做法"
  api_key: ""
  base_url: "https://api.deepseek.com"
  model: "deepseek-chat"
  recommend_cache_ttl_hours: 24
  recommend_count: 5
  rate_limit:
    recommend:
      enabled: true
      max_requests: 5
      window_hours: 2
    catalog:
      enabled: true
      max_requests: 5
      window_hours: 2

notification:
  enabled: true
  retry:
    max_attempts: 3
    intervals_sec: [60, 300, 900]

  websocket:
    enabled: true
    path: "/api/ws"
    ping_interval_sec: 30
    read_timeout_sec: 60

  wechat_subscribe:
    enabled: true
    template_id: "YOUR_TEMPLATE_ID"
    miniprogram_state: "formal"
    page: "pages/order/order"

  wecom_workbench:
    enabled: true
    corp_id: "YOUR_CORP_ID"
    agent_id: 1000002
    secret: "YOUR_AGENT_SECRET"
    api_base: "https://qyapi.weixin.qq.com"
    msg_type: "news"
    card_url: "https://www.zzzjc.xin"
    mini_appid: ""                    # 可选；留空则使用 wechat.appid
    mini_pagepath: "pages/order/order" # 与 mini_appid 同时有效时，卡片点击打开小程序（优先于 card_url）
    default_cover_url: ""
    duplicate_check_interval: 1800

  server_chan:
    enabled: true
    api_base: "https://sctapi.ftqq.com"

  bark:
    enabled: true
    default_endpoint: "https://api.day.app"

  ntfy:
    enabled: true
    default_endpoint: "https://ntfy.sh"
    default_priority: "high"
    default_tags: "cooking,food"

  worker:
    enabled: true
    poll_interval_sec: 30

image_worker:
  enabled: true
  path: "/api/ws/image-worker"
  token: "CHANGE_ME_GATEWAY_SECRET"
  ping_interval_sec: 30
  read_timeout_sec: 120

fridge:
  enabled: true

blind_box:
  enabled: true
  rate_limit:
    enabled: true
    max_requests: 30
    window_hours: 3
